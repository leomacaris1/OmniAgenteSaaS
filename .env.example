OMNIAGENT_MODEL_PROVIDER=local
OMNIAGENT_STORAGE_DRIVER=file
OMNIAGENT_PRIVATE_MVP_PROJECT_LIMIT=5
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omniagent
# Optional. Only needed with OMNIAGENT_STORAGE_DRIVER=prisma if you want to pin
# projects to a pre-seeded organization instead of the auto-created default one.
OMNIAGENT_DEFAULT_ORG_ID=
