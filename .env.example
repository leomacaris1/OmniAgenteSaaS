OMNIAGENT_MODEL_PROVIDER=local
OMNIAGENT_STORAGE_DRIVER=file
OMNIAGENT_PRIVATE_MVP_PROJECT_LIMIT=5
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
# Precios aproximados por millon de tokens para estimar costo por ejecucion.
# Solo informativo, no es fuente de verdad de facturacion.
OPENAI_PRICE_INPUT_PER_1M=0.25
OPENAI_PRICE_OUTPUT_PER_1M=2
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omniagent
