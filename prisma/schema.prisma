generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MEMBER
}

/// CONTRACT: id must equal the corresponding Supabase `auth.users.id` (uuid),
/// assigned by the app at signup time (e.g. in a Supabase Auth webhook/trigger
/// handler) — never generated here. Do NOT add `@default(...)` to this field:
/// doing so breaks the 1:1 identity link with Supabase Auth and orphans any
/// row created that way. This table does NOT introspect or duplicate
/// Supabase's `auth` schema — it is OmniAgent's own application-level user
/// record, kept in sync by id with the Supabase auth user (future phase,
/// not wired yet).
model User {
  id              String               @id
  email           String               @unique
  name            String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  memberships     OrganizationMember[]
  projectsCreated Project[]            @relation("ProjectCreatedBy")
}

/// slug "default" is reserved for the auto-created fallback organization used
/// while there is no auth/session to resolve a real org from (see
/// src/lib/omniagent/storage/default-organization.ts). When org creation gets
/// a real UI/API, it must reject "default" as a user-chosen slug to avoid a
/// unique-constraint collision with that seeded row.
model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   OrganizationMember[]
  projects  Project[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Project {
  id              String              @id @default(cuid())
  organizationId  String
  createdByUserId String?
  builderKey      String              @default("saas")
  title           String
  idea            String
  audience        String?
  region          String?
  constraints     String?
  provider        String
  promptVersion   String
  output          Json
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdByUser   User?               @relation("ProjectCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  runs            AgentRun[]
  artifacts       GeneratedArtifact[]
  id             String              @id @default(cuid())
  workspaceId    String?
  title          String
  idea           String
  audience       String?
  region         String?
  constraints    String?
  provider       String
  promptVersion  String
  output         Json
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  workspace      Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs           AgentRun[]
  artifacts      GeneratedArtifact[]
  feedback        PilotFeedback[]

  @@index([workspaceId])
}

model AgentRun {
  id        String   @id @default(cuid())
  projectId String
  builder   String
  provider  String
  agents    String[]
  status    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PromptVersion {
  id        String   @id @default(cuid())
  key       String
  version   String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([key, version])
}

model GeneratedArtifact {
  id        String   @id @default(cuid())
  projectId String
  type      String
  title     String
  content   Json
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AppUser {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sessions     UserSession[]
  memberships  WorkspaceMember[]
  feedback     PilotFeedback[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  projects  Project[]
  feedback  PilotFeedback[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("owner")
  createdAt   DateTime  @default(now())
  user        AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PilotFeedback {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  projectId   String?
  rating      Int?
  message     String
  status      String    @default("open")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
}
