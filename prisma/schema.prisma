generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MEMBER
}

/// id is expected to equal the corresponding Supabase `auth.users.id` (uuid)
/// once Supabase Auth is wired up in a later phase. This table does NOT
/// introspect or duplicate Supabase's `auth` schema — it is OmniAgent's own
/// application-level user record, kept in sync by id with Supabase's auth
/// user at signup time (future phase).
model User {
  id              String               @id
  email           String               @unique
  name            String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  memberships     OrganizationMember[]
  projectsCreated Project[]            @relation("ProjectCreatedBy")
}

model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   OrganizationMember[]
  projects  Project[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Project {
  id              String              @id @default(cuid())
  organizationId  String
  createdByUserId String?
  builderKey      String              @default("saas")
  title           String
  idea            String
  audience        String?
  region          String?
  constraints     String?
  provider        String
  promptVersion   String
  output          Json
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdByUser   User?               @relation("ProjectCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  runs            AgentRun[]
  artifacts       GeneratedArtifact[]
}

model AgentRun {
  id        String   @id @default(cuid())
  projectId String
  builder   String
  provider  String
  agents    String[]
  status    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PromptVersion {
  id        String   @id @default(cuid())
  key       String
  version   String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([key, version])
}

model GeneratedArtifact {
  id        String   @id @default(cuid())
  projectId String
  type      String
  title     String
  content   Json
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
